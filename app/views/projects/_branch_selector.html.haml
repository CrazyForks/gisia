- ref_with_path = @path.present? && @path != '/' ? "PLACEHOLDER/#{@path}" : "PLACEHOLDER"
- url_template = namespace_project_tree_path(@project.namespace.parent.full_path, @project.namespace.path, ref_with_path, ref_type: ExtractsRef::RefExtractor::BRANCH_REF_TYPE)
%div{ class: 'flex items-center gap-2' }
  = icon 'git-branch', class: 'w-4 h-4 text-slate-500'
  %span{ class: 'text-sm font-medium text-slate-700' }
    = _('Branch:')
  = select_tag :ref, options_for_select(@branches, @current_ref), class: 'text-sm bg-white border border-slate-300 rounded px-2 py-1 text-slate-900 font-medium', data: { controller: 'ref-selector', ref_selector_url_template_value: url_template, action: 'change->ref-selector#navigate' }
