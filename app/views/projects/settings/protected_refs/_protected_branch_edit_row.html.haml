%turbo-frame{id: "protected_branch_row_#{protected_ref.id}"}
  %div{class: 'border border-blue-200 rounded-lg p-4 bg-blue-50'}
    = form_with model: protected_ref, url: namespace_project_settings_protected_branch_path(project.namespace.parent.full_path, project.namespace.path, protected_ref), method: :patch, html: { class: 'space-y-3' } do |f|
      %div{class: 'grid grid-cols-1 lg:grid-cols-2 gap-3'}
        %div
          = f.label :name, _('Branch pattern'), class: 'block text-sm font-medium text-gray-900 mb-1'
          = f.text_field :name, class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white'
        %div
          = f.label :access_level, _('Required access level'), class: 'block text-sm font-medium text-gray-900 mb-1'
          = f.select :access_level, options_for_select([[_('Developer'), 'developer'], [_('Maintainer'), 'maintainer'], [_('Owner'), 'owner']], protected_ref.access_level), {}, { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white' }
      %div{class: 'flex flex-wrap items-center gap-4'}
        %label{class: 'flex items-center gap-1.5 cursor-pointer'}
          = f.check_box :allow_push, class: 'w-4 h-4 text-blue-600 border-gray-300 rounded'
          %span{class: 'text-sm text-gray-700'}= _('Allow push')
        %label{class: 'flex items-center gap-1.5 cursor-pointer'}
          = f.check_box :allow_force_push, class: 'w-4 h-4 text-blue-600 border-gray-300 rounded'
          %span{class: 'text-sm text-gray-700'}= _('Force push')
        %label{class: 'flex items-center gap-1.5 cursor-pointer'}
          = f.check_box :allow_merge_to, class: 'w-4 h-4 text-blue-600 border-gray-300 rounded'
          %span{class: 'text-sm text-gray-700'}= _('Allow merge')
      %div{class: 'flex justify-end gap-2 pt-1'}
        = link_to _('Cancel'), namespace_project_settings_protected_branch_path(project.namespace.parent.full_path, project.namespace.path, protected_ref), class: 'px-3 py-1.5 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors'
        = f.submit _('Save changes'), class: 'px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer'
