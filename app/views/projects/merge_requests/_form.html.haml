- form_url = @merge_request.new_record? ? namespace_project_merge_requests_path : namespace_project_merge_request_path(@project.namespace.parent.full_path, @project.path, @merge_request)
- cancel_url = @merge_request.new_record? ? namespace_project_merge_requests_path(@project.namespace.parent.full_path, @project.path) : namespace_project_merge_request_path(@merge_request.target_project.namespace.parent.full_path, @merge_request.target_project.path, @merge_request)

- conflicting_mr = @merge_request.new_record? && @merge_request.existing_mrs_targeting_same_branch.first
- if conflicting_mr
  %div{ class: 'bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6' }
    %div{ class: 'flex items-start gap-3' }
      = icon 'warning', class: 'w-5 h-5 text-yellow-500 mt-0.5 shrink-0'
      %p{ class: 'text-sm text-yellow-800' }
        = _('These branches already have an open merge request:')
        = link_to conflicting_mr.to_reference, namespace_project_merge_request_path(conflicting_mr.target_project.namespace.parent.full_path, conflicting_mr.target_project.path, conflicting_mr), class: 'font-medium underline', target: '_blank'

= form_with model: @merge_request, url: form_url, local: true, data: { turbo: false } do |f|
  - other_errors = @merge_request.errors.reject { |e| e.attribute.to_sym == :validate_branches }
  - if other_errors.any?
    %div{ class: 'bg-red-50 border border-red-200 rounded-lg p-4 mb-6' }
      %div{ class: 'flex' }
        = icon 'warning', class: 'w-5 h-5 text-red-400 mt-0.5'
        %div{ class: 'ml-3' }
          %h3{ class: 'text-sm font-medium text-red-800' }= _('Unable to save merge request')
          %ul{ class: 'mt-1 text-sm text-red-700 list-disc list-inside' }
            - other_errors.each do |error|
              %li= error.full_message

  %div{ class: 'space-y-6' }
    - if @merge_request.new_record?
      %div{ class: 'hidden' }
        = f.select :source_project_id, options_from_collection_for_select(@projects, :id, :name), {}, class: 'w-full px-3 py-2 border border-slate-300 rounded-lg'
        = f.select :target_project_id, options_from_collection_for_select(@projects, :id, :name), {}, class: 'w-full px-3 py-2 border border-slate-300 rounded-lg'

    %div{ class: 'grid grid-cols-1 md:grid-cols-2 gap-6' }
      %div
        %label{ class: 'block text-sm font-medium text-slate-700 mb-2' }= _('Source Branch')
        = render 'shared/branch_select', field_name: 'merge_request[source_branch]', selected: @merge_request.source_branch

      %div
        %label{ class: 'block text-sm font-medium text-slate-700 mb-2' }= _('Target Branch')
        = render 'shared/branch_select', field_name: 'merge_request[target_branch]', selected: (@merge_request.target_branch || @project.default_branch)

    %div
      %label{ class: 'block text-sm font-medium text-slate-700 mb-2' }= _('Title')
      = f.text_field :title, class: 'w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500', placeholder: _('Enter merge request title')

    %div
      %label{ class: 'block text-sm font-medium text-slate-700 mb-2' }= _('Description')
      = render 'shared/markdown_editor', f: f, field: :description, placeholder: _('Describe the changes in this merge request'), min_height: 'min-h-48', initial_content: @merge_request.description || '', textarea_id: 'merge-request-description-editor', upload_url: namespace_project_uploads_path(@project.namespace.parent.full_path, @project.path), upload_prefix: "/-/project/#{@project.id}"

  %div{ class: 'flex items-center gap-4 pt-6 border-t border-slate-200 mt-6' }
    = f.submit (@merge_request.new_record? ? _('Create Merge Request') : _('Update Merge Request')), class: 'px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors duration-200'
    = link_to _('Cancel'), cancel_url, class: 'px-6 py-2 border border-slate-300 text-slate-700 hover:bg-slate-50 rounded-lg font-medium transition-colors duration-200'
