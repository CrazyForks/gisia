- user = @namespace.creator

- content_for :breadcrumb do
  - nodes = [{ label: user.username, path: namespace_show_path(@namespace.full_path) }]
  = render 'shared/breadcrumb', nodes: nodes

%div{class: 'w-full bg-white p-2 rounded-lg'}
  %div{class: 'w-full max-w-6xl mx-auto'}
    %div{class: 'py-6'}
      %div{class: 'flex items-center gap-4 mb-8'}
        %div{class: 'w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-600 flex items-center justify-center text-white'}
          = icon 'user', class: 'w-8 h-8'
        %div
          %h1{class: 'text-2xl font-bold text-gray-900'}= user.name
          %p{class: 'text-gray-500 text-sm'}= "@#{user.username}"

      %div{class: 'mb-4'}
        %h2{class: 'text-lg font-semibold text-gray-900'} Public Projects

      - if @projects.any?
        = render 'dashboard/projects/project_list', projects: @projects, namespace_prefix: user.username
      - else
        %div{class: 'text-center py-16'}
          %div{class: 'w-14 h-14 rounded-full bg-blue-50 flex items-center justify-center mx-auto mb-4'}
            = icon 'folder', class: 'w-7 h-7 text-blue-400'
          %p{class: 'text-gray-500 text-sm'} No public projects
