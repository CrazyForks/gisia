- thread_expanded = local_assigns.fetch(:thread_expanded, !note.resolved?)
- collapsed = note.resolved? && !thread_expanded
%div{ id: "note_#{note.id}" }
  %div{ class: "flex gap-3 p-4 border border-slate-200 rounded-lg" }
    = render 'shared/user_avatar', user: note.author, size: 32, css_class: 'w-8 h-8 rounded-full flex-shrink-0'

    %div{ class: "flex-1 min-w-0" }
      %div{ class: "flex items-center justify-between mb-1" }
        %div{ class: "flex items-center gap-2" }
          - if note.diff_note? && local_assigns.fetch(:show_diff_link, false)
            %span{ class: "text-sm" }
              %span{ class: "font-medium" }= note.author.name
              %span{ class: "text-sm text-slate-500" }
                commented on
                = link_to 'diff', diffs_namespace_project_merge_request_path(note.noteable.project.namespace.parent.full_path, note.noteable.project.path, note.noteable, anchor: note.line_code, diff_anchor: note.line_code), class: 'text-slate-800'
                = "#{time_ago_in_words(note.created_at)} ago"
              - if note.last_edited_at.present?
                %span{ class: "text-xs text-slate-400 ml-1" } (edited)
          - else
            %span{ class: "font-medium text-sm" }= note.author.name
            %span{ class: "text-xs text-slate-500" }
              = "#{time_ago_in_words(note.created_at)} ago"
              - if note.last_edited_at.present?
                %span{ class: "text-xs text-slate-400 ml-1" } (edited)

        - unless collapsed
          %div{ class: "flex items-center gap-1 text-xs text-slate-500" }
            - if note.root_note?
              - if note.resolved?
                = button_to 'Unresolve', resolve_note_path(note), method: :delete, class: 'hover:text-slate-700 bg-transparent border-0 px-1 py-0.5 text-xs text-green-600', form_class: 'inline'
              - else
                = button_to 'Resolve', resolve_note_path(note), method: :post, class: 'hover:text-green-700 bg-transparent border-0 px-1 py-0.5 text-xs', form_class: 'inline'
            %div{ class: 'relative', data: { controller: "dashboard" } }
              = link_to '#', class: 'p-1 text-slate-400 hover:text-slate-600 rounded hover:bg-slate-100 block', data: { action: "click->dashboard#toggleMenu" } do
                = icon('dots-three', class: 'w-4 h-4')
              %div{ class: 'absolute right-0 top-full mt-1 bg-white border border-slate-200 rounded-lg hidden z-10 py-0.5 w-fit', data: { "dashboard-target": "menu" } }
                = button_to 'Edit', note_edit_path(note), remote: true, class: 'block px-4 py-1.5 text-xs text-slate-700 hover:bg-slate-50 w-full text-left', form_class: 'w-full'
                = link_to 'Delete', note_path(note), class: 'block px-4 py-1.5 text-xs text-red-600 hover:bg-red-50 text-left', data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this comment?' }

      - if collapsed
        = button_to expand_note_path(note), method: :post, class: "flex items-center gap-1 text-xs text-slate-400 italic bg-transparent border-0 p-0 hover:text-slate-600 cursor-pointer", form_class: "inline" do
          = icon('caret-down', class: "w-3 h-3 flex-shrink-0")
          Resolved by
          %span{ class: "font-medium" }= note.resolved_by.name
          &middot;
          = time_ago_in_words(note.resolved_at)
          ago
      - else
        - if note.resolved?
          %div{ class: "flex items-center gap-1 text-xs text-slate-400 italic mb-2" }
            = button_to collapse_note_path(note), method: :post, class: "flex items-center bg-transparent border-0 p-0 text-slate-400 hover:text-slate-600 cursor-pointer", form_class: "inline" do
              = icon('caret-up', class: "w-3 h-3")
            Resolved by
            %span{ class: "font-medium" }= note.resolved_by.name
            &middot;
            = time_ago_in_words(note.resolved_at)
            ago
        %div{ class: "prose prose-sm max-w-none markdown break-words" }= note.note_html.html_safe
        - if note.root_note?
          - if note.replies.any?
            .ml-8.mt-4.space-y-4
              - note.replies.each do |reply|
                = render 'shared/notes/note', note: reply
          .ml-8.mt-4{ id: "note-#{note.id}-reply-form", data: { controller: "reply-form" } }
            %div{ class: "border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-400 cursor-text bg-white", data: { "reply-form-target": "placeholder", action: "click->reply-form#expand" } }
              Write a reply...
            %div{ class: "hidden", data: { "reply-form-target": "editor" } }
              = form_with url: namespace_project_notes_path(note.noteable.project.namespace.parent.full_path, note.noteable.project.path, target_id: note.noteable.id), scope: :note, local: false, class: "space-y-3" do |f|
                = hidden_field_tag "note[noteable_type]", note.noteable.class.name
                = hidden_field_tag "note[noteable_id]", note.noteable.id
                = hidden_field_tag "note[discussion_id]", note.id
                = hidden_field_tag :target_id, note.noteable.id
                = render 'shared/markdown_editor', f: f, field: :note, placeholder: 'Write a reply...', min_height: 'min-h-40', initial_content: '', textarea_id: "editor-reply-note-#{note.id}"
                .flex.justify-end
                  = f.submit 'Reply', class: 'px-4 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700'
